# Beethoven project manifest — analogous to Cargo.toml.
# The `beethoven` CLI reads this and generates the hidden sbt + cmake builds
# under target/. Users should not need to edit build.sbt or CMakeLists.txt by hand.
#
# Convention: keys that are commented out show their default value. Uncomment
# only to override.

[project]
name = "{{name_snake}}"

[hardware]
# src-dir = "hw"               # optional, default "hw"

## Beethoven-Hardware dependency. Both lines below are commented out by default —
## version pinning is opt-in. Uncomment exactly one before `beethoven build`:
##   `path`    source-links a local checkout (good while iterating on the framework)
##   `version` resolves from the local Ivy cache populated by `beethoven setup`
{{hardware_dep_toml}}
# [software]                   # entire section optional
# src-dir = "sw"               # default "sw"

[platform]
## Deployment target. One of:
##   default | kria | kria2 | aupzu3 | aws-f1 | aws-f2 | u200
##
target = "{{target}}"

## Platform-specific parameters. Only the table matching `platform.target` is
## read. The required keys depend on the chosen target — `aupzu3` needs at
## minimum `dram-size-gb` (the AUPZU3Platform constructor asserts 4 or 8).
{{platform_specific}}

## Build output directory.
# [build]                      # entire section optional
# output-dir = "target"        # default "target"
