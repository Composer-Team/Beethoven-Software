// {{system}} -- minimal Beethoven Verilog accelerator: elementwise
// add of two int32 streams. Per command, the core fires three memory
// requests (read vec_a, read vec_b, write vec_out), pipes a+b through
// one element at a time, then ack's the response when the writer
// flushes.
//
// The framework owns the port list between the BEGIN/END markers below;
// edits inside that region get overwritten on the next build. Everything
// after `);` is your implementation.

module {{system}} (
  // BEETHOVEN-PORTS-BEGIN -- regenerated by Beethoven; edits inside this region will be lost
  input clock,
  input areset,

  input         cmd_{{name_snake}}_valid,
  output        cmd_{{name_snake}}_ready,
  input  [31:0] cmd_{{name_snake}}_vector_length,
  input  [63:0] cmd_{{name_snake}}_vec_out_addr,
  input  [63:0] cmd_{{name_snake}}_vec_b_addr,
  input  [63:0] cmd_{{name_snake}}_vec_a_addr,
  output        resp_{{name_snake}}_valid,
  input         resp_{{name_snake}}_ready,
  output        vec_a_req_valid,
  input         vec_a_req_ready,
  output [31:0] vec_a_req_len,
  output [48:0] vec_a_req_addr_address,
  output        vec_b_req_valid,
  input         vec_b_req_ready,
  output [31:0] vec_b_req_len,
  output [48:0] vec_b_req_addr_address,
  input         vec_a_inProgress,
  input         vec_b_inProgress,
  input         vec_a_data_valid,
  output        vec_a_data_ready,
  input  [31:0] vec_a_data,
  input         vec_b_data_valid,
  output        vec_b_data_ready,
  input  [31:0] vec_b_data,
  output        vec_out_req_valid,
  input         vec_out_req_ready,
  output [31:0] vec_out_req_len,
  output [48:0] vec_out_req_addr_address,
  input         vec_out_isFlushed,
  output        vec_out_data_valid,
  input         vec_out_data_ready,
  output [31:0] vec_out_data
  // BEETHOVEN-PORTS-END
);

    // ---- FSM ---------------------------------------------------------
    //   IDLE    -> WORKING : cmd accepted, three memory requests issued
    //   WORKING -> RESPOND : writer flushed last byte to DRAM
    //   RESPOND -> IDLE    : software ack'd the response handshake
    localparam IDLE    = 2'd0;
    localparam WORKING = 2'd1;
    localparam RESPOND = 2'd2;

    reg [1:0] state;

    always @(posedge clock) begin
        if (areset) state <= IDLE;
        else case (state)
            IDLE:    if (cmd_fire)            state <= WORKING;
            WORKING: if (vec_out_isFlushed)   state <= RESPOND;
            RESPOND: if (resp_{{name_snake}}_valid && resp_{{name_snake}}_ready)
                                              state <= IDLE;
        endcase
    end

    // ---- Cmd handshake -----------------------------------------------
    // Accept a command only when all three channels can also take a
    // request, so cmd accept and req dispatch land in the same cycle.
    wire cmd_fire = cmd_{{name_snake}}_valid && cmd_{{name_snake}}_ready;
    assign cmd_{{name_snake}}_ready = (state == IDLE)
                                    && vec_a_req_ready
                                    && vec_b_req_ready
                                    && vec_out_req_ready;

    // ---- Request issuance --------------------------------------------
    // Fire all three memory requests on cmd_fire. len is identical for
    // reads and writes since one a/b pair produces one out element.
    wire [31:0] len_bytes = cmd_{{name_snake}}_vector_length << 2;

    assign vec_a_req_valid          = cmd_fire;
    assign vec_a_req_len            = len_bytes;
    assign vec_a_req_addr_address   = cmd_{{name_snake}}_vec_a_addr[48:0];

    assign vec_b_req_valid          = cmd_fire;
    assign vec_b_req_len            = len_bytes;
    assign vec_b_req_addr_address   = cmd_{{name_snake}}_vec_b_addr[48:0];

    assign vec_out_req_valid        = cmd_fire;
    assign vec_out_req_len          = len_bytes;
    assign vec_out_req_addr_address = cmd_{{name_snake}}_vec_out_addr[48:0];

    // ---- Datapath ----------------------------------------------------
    // Sum is purely combinational. Advance only when both readers have a
    // datum AND the writer can accept it, keeping a/b/out in lockstep.
    wire pair_valid = vec_a_data_valid && vec_b_data_valid;
    wire fire_pair  = pair_valid && vec_out_data_ready;

    assign vec_out_data       = vec_a_data + vec_b_data;
    assign vec_out_data_valid = pair_valid;
    assign vec_a_data_ready   = fire_pair;
    assign vec_b_data_ready   = fire_pair;

    // ---- Response ----------------------------------------------------
    // Empty payload: hold valid through RESPOND, software acks via ready.
    assign resp_{{name_snake}}_valid = (state == RESPOND);

endmodule
